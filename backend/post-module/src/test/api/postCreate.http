### 1. 게시물 등록
POST {{baseUrl}}/posts
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "mediaList": [
    {
      "mediaUrl": "posts/20260617_unique_image_name.jpg",
      "mediaType": "IMAGE",
      "originalFileName": "dog_profile.jpg",
      "cropState": {
        "crop": {
          "x": 0.0,
          "y": 15.5
        },
        "zoom": 1.2,
        "rotation": 90.0,
        "croppedAreaPixels": {
          "width": 500.0,
          "height": 500.0,
          "x": 10.0,
          "y": 10.0
        }
      }
    },
    {
      "mediaUrl": "posts/20260617_unique_video_name.mp4",
      "mediaType": "VIDEO",
      "originalFileName": "travel_clip.mp4",
      "cropState": null
